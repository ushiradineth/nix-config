{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.1-codex-mini",
  "default_agent": "planner",
  "autoupdate": false,
  "lsp": {},
  "plugin": ["cc-safety-net", "opencode-openai-codex-auth"],
  "mcp": {
    "veil": {
      "type": "local",
      "command": [
        "nix",
        "shell",
        "nixpkgs#bun",
        "-c",
        "bunx",
        "@ushiradineth/veil@latest",
        "server"
      ],
      "environment": {
        "VEIL_SERVER_AUTO_INIT": "1",
        "VEIL_SERVER_AUTO_REFRESH_ON_QUERY": "1",
        "VEIL_SERVER_BACKGROUND_REFRESH": "1",
        "VEIL_SERVER_BACKGROUND_REFRESH_INTERVAL_MS": "300000",
        "VEIL_SERVER_BACKGROUND_MAX_PER_HOUR": "4"
      },
      "enabled": true,
      "timeout": 120000
    }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium"
      }
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "planner": {
      "mode": "primary",
      "description": "Planning authority that creates handoff plans for builder execution",
      "temperature": 0.1,
      "steps": 120,
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "question": "allow",
        "task": "allow",
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": "deny",
        "edit": {
          "*": "deny",
          ".agents/**": "allow"
        }
      }
    },
    "builder": {
      "mode": "primary",
      "description": "Execution authority that implements approved planner handoffs",
      "temperature": 0.1,
      "steps": 80,
      "prompt": "{file:./prompts/build.md}",
      "permission": {
        "question": "allow",
        "task": "allow",
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "git *": "ask",
          "gh *": "ask",
          "sudo *": "ask"
        },
        "edit": "allow",
        "write": "allow",
        "apply_patch": "allow"
      }
    },
    "direct": {
      "mode": "primary",
      "description": "Direct implementation for simple tasks with guarded bash and full file editing",
      "temperature": 0.1,
      "steps": 120,
      "prompt": "{file:./prompts/direct.md}",
      "permission": {
        "question": "allow",
        "task": "allow",
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "git *": "ask",
          "gh *": "ask",
          "sudo *": "ask"
        },
        "edit": "allow",
        "write": "allow",
        "apply_patch": "allow"
      }
    },
    "grind": {
      "mode": "subagent",
      "description": "Long-running autonomous executor for large tasks with checkpoints",
      "temperature": 0.1,
      "steps": 400,
      "prompt": "{file:./prompts/grind.md}",
      "permission": {
        "question": "allow",
        "task": "allow",
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": {
          "*": "allow",
          "rm *": "ask",
          "git *": "ask",
          "gh *": "ask",
          "sudo *": "ask"
        },
        "edit": "allow"
      }
    },
    "audit": {
      "mode": "subagent",
      "description": "Code health auditor for DRY, SOLID, coupling, and maintainability risks",
      "temperature": 0.1,
      "steps": 160,
      "prompt": "{file:./prompts/audit.md}",
      "permission": {
        "question": "allow",
        "task": "allow",
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": "deny",
        "edit": {
          "*": "deny",
          ".agents/**": "allow"
        }
      }
    },
    "ideate": {
      "mode": "subagent",
      "description": "Feature ideation agent for exploring and shaping new product ideas",
      "temperature": 0.8,
      "steps": 140,
      "prompt": "{file:./prompts/ideate.md}",
      "permission": {
        "question": "allow",
        "task": "allow",
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": "deny",
        "edit": {
          "*": "deny",
          ".agents/**": "allow"
        }
      }
    },
    "creative": {
      "mode": "subagent",
      "description": "Creative writing and UI ideation with stronger variation",
      "temperature": 0.7,
      "steps": 80,
      "prompt": "{file:./prompts/creative.md}",
      "permission": {
        "question": "allow",
        "task": "allow",
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": "deny",
        "edit": {
          "*": "deny",
          ".agents/**": "allow"
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": "deny",
    "glob": "deny",
    "list": "deny",
    "grep": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "task": {
      "*": "allow",
      "planner": "deny",
      "builder": "deny",
      "direct": "deny"
    },
    "skill": "allow",
    "lsp": "allow",
    "external_directory": {
      "*": "deny",
      "~/nix-config/**": "allow",
      "~/.config/**": "allow",
      "~/Code/**": "allow",
      "~/Downloads/**": "allow"
    }
  }
}
