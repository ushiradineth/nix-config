{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.1-codex-mini",
  "default_agent": "planner",
  "theme": "system",
  "autoupdate": false,
  "lsp": {},
  "plugin": ["cc-safety-net", "opencode-openai-codex-auth"],
  "mcp": {
    "veil": {
      "type": "local",
      "command": [
        "nix",
        "run",
        "nixpkgs#bun",
        "--",
        "run",
        "--cwd",
        "/Users/shu/Code/veil",
        "src/server.ts"
      ],
      "enabled": true,
      "timeout": 120000
    }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium"
      }
    }
  },
  "agent": {
    "planner": {
      "mode": "primary",
      "description": "Plan-first agent that can write plans and execute after acceptance",
      "temperature": 0.1,
      "steps": 120,
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "question": "allow",
        "task": {
          "*": "allow",
          "builder": "allow",
          "explore": "allow",
          "general": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "ls*": "allow",
          "pwd": "allow"
        },
        "edit": "allow",
        "write": "allow",
        "apply_patch": "allow"
      }
    },
    "builder": {
      "mode": "subagent",
      "description": "Implementation mode with plan-first execution and index-first discovery",
      "temperature": 0.1,
      "steps": 80,
      "prompt": "{file:./prompts/build.md}",
      "permission": {
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "rm *": "ask",
          "sudo *": "ask"
        },
        "edit": "allow"
      }
    },
    "direct": {
      "mode": "subagent",
      "description": "Direct implementation for simple tasks without plan-file handoff",
      "temperature": 0.1,
      "steps": 60,
      "prompt": "{file:./prompts/direct.md}",
      "permission": {
        "question": "allow",
        "task": {
          "*": "allow",
          "explore": "allow",
          "general": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "rm *": "ask",
          "sudo *": "ask"
        },
        "edit": "allow"
      }
    },
    "grind": {
      "mode": "subagent",
      "description": "Long-running autonomous executor for large tasks with checkpoints",
      "temperature": 0.1,
      "steps": 400,
      "prompt": "{file:./prompts/grind.md}",
      "permission": {
        "question": "allow",
        "task": {
          "*": "allow",
          "explore": "allow",
          "general": "allow",
          "direct": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "rm *": "ask",
          "sudo *": "ask"
        },
        "edit": "allow"
      }
    },
    "creative": {
      "mode": "subagent",
      "description": "Creative writing and UI ideation with stronger variation",
      "temperature": 0.7,
      "steps": 80,
      "prompt": "{file:./prompts/creative.md}",
      "permission": {
        "question": "allow",
        "task": {
          "*": "allow",
          "explore": "allow",
          "general": "allow",
          "direct": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "rm *": "ask",
          "sudo *": "ask"
        },
        "edit": "allow"
      }
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": "allow",
    "glob": "allow",
    "list": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "external_directory": "allow"
  }
}
